<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="1772909678326-1" author="andreibeloziorove">
        <createIndex tableName="org_invitation" indexName="IDX_ORG_INVITATION_ON_ORGANIZATION_ID_STATUS">
            <column name="organization_id"/>
            <column name="status"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772909711491-1" author="andreibeloziorove">
        <createIndex tableName="org_invitation" indexName="IDX_ORG_INVITATION_ON_EMAIL_STATUS">
            <column name="email"/>
            <column name="status"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772909731759-1" author="andreibeloziorove">
        <createIndex tableName="org_invitation" indexName="IDX_ORG_INVITATION_ON_CREATED_AT">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
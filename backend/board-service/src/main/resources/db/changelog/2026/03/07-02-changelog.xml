<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-5.0.xsd">

    <changeSet id="1772903163166-1" author="andreibeloziorove">
        <createIndex tableName="boards" indexName="IDX_BOARDS_ON_ORG">
            <column name="org_id"/>
        </createIndex>
        <createIndex tableName="boards" indexName="IDX_BOARDS_ON_OWNER">
            <column name="owner_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772903201229-1" author="andreibeloziorove">
        <createIndex tableName="boards" indexName="IDX_BOARDS_ON_ORG_ID_IS_ARCHIVED">
            <column name="org_id"/>
            <column name="is_archived"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772903225344-1" author="andreibeloziorove">
        <createIndex tableName="board_columns" indexName="IDX_BOARD_COLUMNS_ON_BOARD_ID_NAME">
            <column name="board_id"/>
            <column name="name"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772903242441-1" author="andreibeloziorove">
        <createIndex tableName="board_members" indexName="IDX_BOARD_MEMBERS_ON_BOARD">
            <column name="board_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772903261935-1" author="andreibeloziorove">
        <createIndex tableName="board_members" indexName="IDX_BOARD_MEMBERS_ON_USER">
            <column name="user_id"/>
        </createIndex>
    </changeSet>
    <changeSet id="1772903272843-1" author="andreibeloziorove">
        <createIndex tableName="labels" indexName="IDX_LABELS_ON_ORG_ID_BOARD_ID">
            <column name="org_id"/>
            <column name="board_id"/>
        </createIndex>
    </changeSet>


</databaseChangeLog>
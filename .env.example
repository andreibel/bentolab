# ═══════════════════════════════════════════════════════════════════════════
# Bento — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Generate secrets with:
#   openssl rand -base64 32
# ═══════════════════════════════════════════════════════════════════════════

# ── Security ───────────────────────────────────────────────────────────────
# All three must be unique, random strings. Never reuse them.
JWT_SECRET=change_me_min_32_chars_use_openssl_rand
GATEWAY_INTERNAL_SECRET=change_me_min_32_chars_use_openssl_rand
AUTH_PEPPER=change_me_min_32_chars_use_openssl_rand

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Shared across auth, org, and board databases
POSTGRES_USER=bento
POSTGRES_PASSWORD=change_me_strong_password

# ── MongoDB ────────────────────────────────────────────────────────────────
# Used by task, notification, and attachment services
MONGO_USERNAME=bento
MONGO_PASSWORD=change_me_strong_password

# ── MinIO (file storage) ───────────────────────────────────────────────────
MINIO_ROOT_USER=bento_admin
MINIO_ROOT_PASSWORD=change_me_strong_password

# ── Notifications ──────────────────────────────────────────────────────────
# The From address used in verification and password-reset emails
MAIL_FROM=noreply@yourdomain.com

# The public URL your users reach the app at — used in email links
FRONTEND_URL=http://localhost:3000

# Set to true and add DISCORD_WEBHOOK_URL to enable Discord notifications
DISCORD_ENABLED=false
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# ── Port Overrides (optional) ─────────────────────────────────────────────
# Uncomment to change the host port any service binds to.
# FRONTEND_PORT=3000
# MINIO_CONSOLE_PORT=9001
# MAILHOG_UI_PORT=8025

# ═══════════════════════════════════════════════════════════════════════════
# Bento — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# For local development, the defaults below are ready to use as-is.
#
#   cp .env.template .env
#   docker compose up -d
# ═══════════════════════════════════════════════════════════════════════════

# ── Security ───────────────────────────────────────────────────────────────
# IMPORTANT: Generate unique values for production!
#   openssl rand -base64 32
JWT_SECRET=
GATEWAY_INTERNAL_SECRET=
AUTH_PEPPER=

# ── PostgreSQL ─────────────────────────────────────────────────────────────
# Shared credentials for all PostgreSQL instances (auth, org, board)
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── MongoDB ────────────────────────────────────────────────────────────────
# Used by task-service, notification-service, attachment-service
MONGO_USERNAME=
MONGO_PASSWORD=

# ── MinIO (S3-compatible storage) ──────────────────────────────────────────
# Used by attachment-service for file uploads
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ── Notifications ──────────────────────────────────────────────────────────
MAIL_FROM=noreply@example.com
FRONTEND_URL=http://localhost:3000
DISCORD_ENABLED=false

# ── Frontend ───────────────────────────────────────────────────────────────
# VITE_API_URL is baked into the frontend build (Vite replaces at build time)
VITE_API_URL=http://localhost:8080
VITE_APP_DOMAIN=localhost

# ── Port Overrides (optional) ─────────────────────────────────────────────
# Uncomment to change default host ports
# FRONTEND_PORT=3000
# POSTGRES_AUTH_PORT=5433
# POSTGRES_ORG_PORT=5434
# POSTGRES_BOARD_PORT=5435
# REDIS_PORT=6380
# MONGO_PORT=27017
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MAILHOG_SMTP_PORT=1025
# MAILHOG_UI_PORT=8025
# KAFKA_UI_PORT=8989